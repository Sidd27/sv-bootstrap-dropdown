{
  "name": "sv-bootstrap-dropdown",
  "description": "Bootstrap 5 dropdown component for Svelte 5",
  "author": {
    "name": "Siddharth Pandey"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sidd27/sv-bootstrap-dropdown"
  },
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "svelte": "src/main.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "svelte": "./src/main.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "demo": "vite demo",
    "demo:build": "vite build demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "bootstrap": "^5.0.0",
    "svelte": "^5.53.5"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@testing-library/user-event": "^14.0.0",
    "bootstrap": "^5.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "rollup": "^4.0.0",
    "rollup-plugin-svelte": "^7.2.0",
    "svelte": "^5.53.5",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript": "^7.0.5"
    }
  },
  "license": "Apache-2.0",
  "keywords": [
    "svelte",
    "svelte5",
    "bootstrap",
    "bootstrap5",
    "dropdown"
  ]
}
